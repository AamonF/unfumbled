# ─── API ──────────────────────────────────────────────────────────────────────
# Public base URL of the Unfumbled backend. The backend is the ONLY layer that
# holds the OpenAI API key — the Expo client never sees it.
#
# Required. App start-up throws if this is missing (see lib/env.ts).
#   Local dev:  http://localhost:8787   (or your LAN IP for device testing)
#   Production: https://api.unfumbled.app
EXPO_PUBLIC_API_URL=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# The anon/publishable key is safe to embed in the client — RLS protects data.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── RevenueCat ───────────────────────────────────────────────────────────────
# Get these from: https://app.revenuecat.com → Project → API Keys
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=appl_your_key_here
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=goog_your_key_here

# ─── Analytics (optional) ────────────────────────────────────────────────────
EXPO_PUBLIC_ANALYTICS_KEY=

# ─── Dev Admin (INTERNAL TESTING ONLY) ───────────────────────────────────────
# Set to "true" to enable a hidden test-admin login in DEV builds only.
#
#   Test credentials:
#     email:    admin@unfumbled.dev
#     password: unfumbledadmin123
#
# Also gated by __DEV__ at runtime — this flag has NO effect in production
# bundles. Never set to "true" for a release build. See lib/devAdmin.ts.
EXPO_PUBLIC_ENABLE_DEV_ADMIN=false
